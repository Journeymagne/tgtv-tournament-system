# Copy this file to .env and fill in the values below.
# The DATABASE_URL is assembled from the parts: user, password, host, port, db name.

# PostgreSQL password (also used by docker-compose for the container)
DB_PASSWORD=

# Full connection string — built from the parts above.
# For a local Docker container (default):
# DATABASE_URL=postgres://tgtv:YOUR_PASSWORD@localhost:5432/tgtv_tournament
DATABASE_URL=

# Remote managed PostgreSQL services often require SSL.
# If your service requires SSL, set PGSSL=true.
# PGSSL=true
